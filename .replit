modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd CartasdoLitoral/nextapp && pnpm dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 18990
externalPort = 3000

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd CartasdoLitoral && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/cartas-do-litoral run build"]
publicDir = "CartasdoLitoral/artifacts/cartas-do-litoral/dist/public"
